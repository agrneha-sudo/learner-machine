# ── Razorpay (keep if account gets unblocked) ─────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_...

# ── Cashfree ───────────────────────────────────────────────────────────────────
# Get from https://merchant.cashfree.com/merchants/developer → API Keys
# Use test credentials for sandbox, live for production
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=

# ── Instamojo ──────────────────────────────────────────────────────────────────
# Get from https://www.instamojo.com/developers → API & Auth tokens
# Test: https://test.instamojo.com/developers
INSTAMOJO_API_KEY=
INSTAMOJO_AUTH_TOKEN=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Admin Auth ─────────────────────────────────────────────────────────────────
# Set a strong password for your admin panel
ADMIN_PASSWORD=change_me_to_something_strong
# Random 32+ char secret for signing admin JWT tokens
ADMIN_JWT_SECRET=change_me_to_a_random_32_char_secret_string

# ── Resend (email) ─────────────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
# Free tier: 3,000 emails/month
RESEND_API_KEY=re_...

# ── Site ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000
